// Velora — Ride-hailing platform schema
// Datasource & generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  RIDER
  DRIVER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  DRIVER_LICENSE
  ID_CARD
  VEHICLE_REGISTRATION
  INSURANCE
  PROFILE_PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideStatus {
  DRAFT
  SEARCHING
  NEGOTIATING
  ACCEPTED
  ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  CASH
  CARD
  PAYPAL
  CRYPTO
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum NotificationType {
  RIDE
  CHAT
  SYSTEM
  PROMO
  SAFETY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────────────────────────────────────────
// Users & auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  emailVerified   Boolean       @default(false)
  passwordHash    String?
  name            String
  phone           String?       @unique
  avatarUrl       String?
  role            Role          @default(RIDER)
  status          AccountStatus @default(ACTIVE)
  authProvider    AuthProvider  @default(LOCAL)
  googleId        String?       @unique
  locale          String        @default("en")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  refreshTokens   RefreshToken[]
  verifyTokens    VerificationToken[]
  resetTokens     PasswordResetToken[]
  driver          DriverProfile?
  rides           Ride[]               @relation("RiderRides")
  driverRides     Ride[]               @relation("DriverRides")
  savedPlaces     SavedPlace[]
  paymentMethods  PaymentMethodRecord[]
  ratingsGiven    Rating[]             @relation("RatingsGiven")
  ratingsReceived Rating[]             @relation("RatingsReceived")
  messagesSent    ChatMessage[]
  notifications   Notification[]
  referralsMade   Referral[]           @relation("Referrer")
  referredBy      Referral?            @relation("Referred")
  fraudAlerts     FraudAlert[]
  sosEvents       SosEvent[]

  @@index([role, status])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Driver profile, vehicles, documents
// ─────────────────────────────────────────────────────────────────────────────

model DriverProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          DriverStatus  @default(PENDING)
  licenseNumber   String?
  licenseExpiry   DateTime?
  rating          Float         @default(5.0)
  totalRides      Int           @default(0)
  totalEarnings   Decimal       @default(0) @db.Decimal(12, 2)
  isOnline        Boolean       @default(false)
  lastSeenAt      DateTime?
  // Latest known location (lat/lng), updated by socket pings
  lastLat         Float?
  lastLng         Float?
  vehicles        Vehicle[]
  documents       DriverDocument[]
  payouts         Payout[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, isOnline])
}

model Vehicle {
  id          String   @id @default(cuid())
  driverId    String
  driver      DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
  make        String
  model       String
  year        Int
  color       String
  plate       String   @unique
  capacity    Int      @default(4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([driverId])
}

model DriverDocument {
  id         String         @id @default(cuid())
  driverId   String
  driver     DriverProfile  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type       DocumentType
  fileUrl    String
  status     DocumentStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([driverId, type])
}

model Payout {
  id          String   @id @default(cuid())
  driverId    String
  driver      DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  method      String
  reference   String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  @@index([driverId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Rides, offers, chat, ratings
// ─────────────────────────────────────────────────────────────────────────────

model Ride {
  id              String        @id @default(cuid())
  riderId         String
  rider           User          @relation("RiderRides", fields: [riderId], references: [id])
  driverId        String?
  driver          User?         @relation("DriverRides", fields: [driverId], references: [id])
  status          RideStatus    @default(DRAFT)

  pickupLabel     String
  pickupLat       Float
  pickupLng       Float
  dropoffLabel    String
  dropoffLat      Float
  dropoffLng      Float

  distanceKm      Float?
  durationSec     Int?
  proposedFare    Decimal       @db.Decimal(10, 2)
  finalFare       Decimal?      @db.Decimal(10, 2)
  surgeMultiplier Float         @default(1.0)
  paymentMethod   PaymentMethod @default(CASH)
  promoCode       String?

  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  offers          RideOffer[]
  events          RideEvent[]
  payment         Payment?
  chatMessages    ChatMessage[]
  ratings         Rating[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([riderId, status])
  @@index([driverId, status])
  @@index([status, createdAt])
}

model RideOffer {
  id         String      @id @default(cuid())
  rideId     String
  ride       Ride        @relation(fields: [rideId], references: [id], onDelete: Cascade)
  driverId   String
  amount     Decimal     @db.Decimal(10, 2)
  etaSeconds Int
  status     OfferStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  @@index([rideId, status])
}

model RideEvent {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([rideId, createdAt])
}

model Rating {
  id          String   @id @default(cuid())
  rideId      String
  ride        Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("RatingsGiven", fields: [authorId], references: [id])
  subjectId   String
  subject     User     @relation("RatingsReceived", fields: [subjectId], references: [id])
  stars       Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([rideId, authorId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([rideId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Saved places, payments, promos, referrals, notifications
// ─────────────────────────────────────────────────────────────────────────────

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  address   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  @@index([userId])
}

model PaymentMethodRecord {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  brand         String?
  last4         String?
  externalId    String?
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([userId])
}

model Payment {
  id              String        @id @default(cuid())
  rideId          String        @unique
  ride            Ride          @relation(fields: [rideId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  externalId      String?
  paidAt          DateTime?
  refundedAt      DateTime?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   // PERCENT or FIXED
  discountValue Decimal  @db.Decimal(10, 2)
  maxRedemptions Int?
  redemptions   Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id])
  rewardAmount Decimal  @default(0) @db.Decimal(10, 2)
  rewardedAt   DateTime?
  createdAt    DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}

model FraudAlert {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  severity  AlertSeverity @default(LOW)
  type      String
  details   Json?
  resolvedAt DateTime?
  createdAt DateTime      @default(now())

  @@index([severity, createdAt])
}

model SosEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rideId    String?
  lat       Float?
  lng       Float?
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Platform settings — singleton row used by admin
model PlatformSetting {
  id                 String   @id @default("singleton")
  commissionPercent  Float    @default(15)
  minSurge           Float    @default(1.0)
  maxSurge           Float    @default(3.0)
  baseFare           Decimal  @default(2.5) @db.Decimal(10, 2)
  perKm              Decimal  @default(1.2) @db.Decimal(10, 2)
  perMinute          Decimal  @default(0.25) @db.Decimal(10, 2)
  updatedAt          DateTime @updatedAt
}
