NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000

DATABASE_URL=postgresql://indrive:indrive_dev_password@localhost:5432/indrive?schema=public
REDIS_URL=redis://default:indrive_redis_password@localhost:6379

# JWT
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Email (use any SMTP provider; left blank disables real sends)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Velora <no-reply@velora.app>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Stripe (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
