# Velora — AI agents API keys
# Copy this file to .env and fill in the keys you have.
# You only need ONE of OpenAI / Anthropic to get started.
# Most agents default to GPT-4 family unless overridden.

# ── OpenAI (Aider, OI, CrewAI, GPT-Researcher all support this) ──
OPENAI_API_KEY=

# ── Anthropic Claude (Aider, OI, CrewAI all support this) ────────
ANTHROPIC_API_KEY=

# ── Optional: search backend for GPT-Researcher ──────────────────
# Recommended: Tavily (free tier 1000 req/mo) — https://tavily.com
TAVILY_API_KEY=

# ── Optional: OpenAI base URL override (LiteLLM, Azure, OpenRouter) ──
# OPENAI_API_BASE=https://openrouter.ai/api/v1
